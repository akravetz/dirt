__pycache__/
*.pyc

# IDE
.idea/
.vscode/

# Testing
.testmondata

# Playwright MCP
.playwright-mcp/

# Screenshots (temp). Phase-2 evaluator reference screenshots under
# docs/plans/refs/ are committed — they're the visual acceptance
# anchors for the rewrite, regenerated from debug/offline.html via
# agent-browser. Keep this carve-out scoped to that directory only.
*.png
!docs/plans/refs/*.png

# Firmware build artifacts
firmware/.pio/
firmware/plant_node/.pio/
firmware/fan_controller/.pio/

# Camera daemon compiled binary (build output, not source)
services/camera-daemon/dirt-camera-daemon

# Firmware secrets (WiFi creds, OTA password, ingest token) — one per node project
firmware/plant_node/src/secrets.h
firmware/fan_controller/include/secrets.h
firmware/reservoir_node/src/secrets.h

# Distribution
dist/
*.egg-info/

# Scratch / sandbox (see CLAUDE.md)
debug/

# macOS Finder metadata
.DS_Store

# Runtime data directory: dirt.db, snapshots/, archives/, logs/, sessions/,
# raw/photos/, outputs/, db-backups/. Set DIRT_DATA_DIR to override.
var/
.claude/worktrees/
