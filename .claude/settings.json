{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "# Protects: apps/tests/invariants/** .githooks/** web-ui/invariants/** web-ui/src/api-client/generated/**\n\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-invariants.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "# Protects: apps/tests/invariants/** .githooks/** web-ui/invariants/** web-ui/src/api-client/generated/**\n\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-invariants-bash.sh"
          }
        ]
      }
    ]
  }
}
