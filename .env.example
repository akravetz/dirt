AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Postgres (see ADR-006). The app assembles DATABASE_URL from the
# DIRT_PG_* components below, but you can set it explicitly to override
# (e.g. pointing at a staging or rehearsal DB).
DIRT_PG_HOST=127.0.0.1
DIRT_PG_PORT=5432
DIRT_PG_USER=dirt
DIRT_PG_PASSWORD=
DIRT_PG_DATABASE=dirt
# DATABASE_URL=postgresql+asyncpg://dirt:PASSWORD@127.0.0.1:5432/dirt

SNAPSHOT_DIR=snapshots
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
SENSOR_INGEST_TOKEN=
PLANT_OTA_PASSWORD=
DEEPGRAM_API_KEY=
ELABS_API_KEY=
ELABS_VOICE_ID=
ANTHROPIC_API_KEY=
KASA_USERNAME=
KASA_PASSWORD=
RUNPOD_API_KEY=
# Container-registry auth ID returned by POST /v1/containerregistryauth.
# Required when the trainer image is on a private registry (e.g. GHCR private).
RUNPOD_GHCR_AUTH_ID=
# ID of the wake-word Network Volume (one-time, via the RunPod console).
# Bucket name for the S3-compatible API; mount path /workspace on training pods.
RUNPOD_NETWORK_VOLUME_ID=
# Datacenter the volume lives in; selects the S3 endpoint hostname
# (https://s3api-<lower>.runpod.io/).
RUNPOD_VOLUME_DATACENTER=US-IL-1
# Dedicated S3 keys generated at Console → Settings → S3 API Keys.
# Separate from RUNPOD_API_KEY (which is for the REST control plane).
RUNPOD_S3_ACCESS_KEY_ID=
RUNPOD_S3_SECRET_ACCESS_KEY=
WANDB_API_KEY=
