AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Postgres (see ADR-006). The app assembles DATABASE_URL from the
# DIRT_PG_* components below, but you can set it explicitly to override
# (e.g. pointing at a staging or rehearsal DB).
DIRT_PG_HOST=127.0.0.1
DIRT_PG_PORT=5432
DIRT_PG_USER=dirt
DIRT_PG_PASSWORD=
DIRT_PG_DATABASE=dirt
# DATABASE_URL=postgresql+asyncpg://dirt:PASSWORD@127.0.0.1:5432/dirt

SNAPSHOT_DIR=snapshots
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
DIRT_DAILY_REPORT_SYNTHESIS_BACKEND=codex
# Optional when systemd's PATH cannot find Codex. Example:
# DIRT_DAILY_REPORT_CODEX_BIN=/home/akcom/.local/share/fnm/node-versions/v24.14.0/installation/bin/codex
DIRT_DAILY_REPORT_CODEX_BIN=codex
DIRT_DAILY_REPORT_CODEX_MODEL=
DIRT_DAILY_REPORT_CODEX_SANDBOX=workspace-write
SENSOR_INGEST_TOKEN=
PLANT_OTA_PASSWORD=
DEEPGRAM_API_KEY=
ELABS_API_KEY=
ELABS_VOICE_ID=
ANTHROPIC_API_KEY=
KASA_USERNAME=
KASA_PASSWORD=
# Govee Public API v2 key (Profile → About Us → Apply for API Key in the
# Govee Home app). Account-wide; controls every Govee device on the account.
# Used to drive the H7142 tent humidifier — see
# docs/references/govee-api/INDEX.md.
GOVEE_API_KEY=
# Optional: pin the device MAC so a same-SKU replacement is intentional,
# not implicit. Empty → discover by SKU at startup.
GOVEE_HUMIDIFIER_SKU=H7142
GOVEE_HUMIDIFIER_MAC=
RUNPOD_API_KEY=
# Container-registry auth ID returned by POST /v1/containerregistryauth.
# Required when the trainer image is on a private registry (e.g. GHCR private).
RUNPOD_GHCR_AUTH_ID=
# ID of the wake-word Network Volume (one-time, via the RunPod console).
# Bucket name for the S3-compatible API; mount path /workspace on training pods.
RUNPOD_NETWORK_VOLUME_ID=
# Datacenter the volume lives in; selects the S3 endpoint hostname
# (https://s3api-<lower>.runpod.io/).
RUNPOD_VOLUME_DATACENTER=US-IL-1
# Dedicated S3 keys generated at Console → Settings → S3 API Keys.
# Separate from RUNPOD_API_KEY (which is for the REST control plane).
RUNPOD_S3_ACCESS_KEY_ID=
RUNPOD_S3_SECRET_ACCESS_KEY=
WANDB_API_KEY=
GOVEE_API_KEY=

# Railway / hosted control plane. RAILWAY_API_TOKEN belongs only in local
# ignored env files and is used by the Railway CLI for infrastructure setup.
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_NAME=dirt-control-plane
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT=production
RAILWAY_ENVIRONMENT_ID=
RAILWAY_CONTROL_PLANE_API_SERVICE_ID=
RAILWAY_WEB_UI_SERVICE_ID=
RAILWAY_POSTGRES_SERVICE_ID=
RAILWAY_ASSETS_BUCKET_ID=

# Local gateway -> hosted control plane.
DIRT_CLOUD_API_BASE_URL=https://api.sirius-forge.com
DIRT_CLOUD_UI_BASE_URL=https://sirius-forge.com
DIRT_CLOUD_SITE_ID=homebox
DIRT_CLOUD_GATEWAY_ID=homebox-gateway
DIRT_CLOUD_GATEWAY_TOKEN=
DIRT_CLOUD_SYNC_INTERVAL_S=30
DIRT_CLOUD_COMMAND_POLL_INTERVAL_S=5
DIRT_CLOUD_ASSET_SYNC_ENABLED=true
DIRT_CLOUD_DRY_RUN=false

# Daily report scoped inputs.
DIRT_DAILY_REPORT_TENT_IDS=main,breeding
DIRT_DAILY_REPORT_REQUIRED_TENT_IDS=main
DIRT_DAILY_REPORT_PHOTO_TENT_IDS=breeding

# Production cloud API secrets. Keep real values in .env.prod only.
DIRT_CLOUD_ADMIN_USERNAME=admin
DIRT_CLOUD_ADMIN_PASSWORD_HASH=
DIRT_CLOUD_DATABASE_URL=
DIRT_CLOUD_ALLOWED_ORIGINS=https://sirius-forge.com
DIRT_CLOUD_GATEWAY_TOKEN_SHA256=
DIRT_CLOUD_SESSION_SECRET=
DIRT_CLOUD_ASSET_RETENTION_DAYS=30
DIRT_CLOUD_COMMAND_CREATION_ENABLED=true
DIRT_CLOUD_GATEWAY_COMMAND_CLAIM_ENABLED=true
DIRT_CLOUD_BUCKET_NAME=dirt-assets
DIRT_CLOUD_S3_ENDPOINT=
DIRT_CLOUD_S3_REGION=iad
DIRT_CLOUD_S3_ACCESS_KEY_ID=
DIRT_CLOUD_S3_SECRET_ACCESS_KEY=
VITE_DIRT_API_BASE_URL=https://api.sirius-forge.com
