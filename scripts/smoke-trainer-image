#!/usr/bin/env bash
# End-to-end smoke test of the trainer image against tiny fixtures.
#
# Builds nothing — pulls/uses whatever image tag is passed (default :latest).
# Mounts the fixtures generated by `scripts/gen-smoke-fixtures` into the
# container at /workspace/input, lets the entrypoint write to /workspace/
# {working,out}, and asserts the SUCCESS sentinel + .onnx artifact land.
#
# Tiny config overrides (DIRT_WAKE_WORD_N_SAMPLES=20, _VAL=10, _STEPS=20)
# keep wall time to ~3-5 min on CPU. Anything that fails — install gap,
# import error, missing config plumbing, code path — fails here, locally,
# before we burn $3 of RunPod GPU time.
#
# Usage:
#   scripts/smoke-trainer-image                       # uses :latest
#   scripts/smoke-trainer-image v3                    # uses :v3

set -euo pipefail

REPO=$(git rev-parse --show-toplevel)
GHCR_OWNER="${GHCR_OWNER:-akravetz}"
IMAGE="ghcr.io/${GHCR_OWNER}/dirt-wake-word-trainer"
TAG="${1:-latest}"
FIXTURES="$REPO/var/wake-word/smoke-fixtures"
SCRATCH=$(mktemp -d -t wake-smoke.XXXXXX)
# Container runs as root and writes root-owned files into the bind-mount.
# Clean up via a throwaway alpine container so we don't need sudo on the host.
trap 'docker run --rm -v "$SCRATCH:/s" alpine rm -rf /s/working /s/out 2>/dev/null; rm -rf "$SCRATCH"' EXIT

if [ ! -d "$FIXTURES/dirt-wakeword-mine" ]; then
  echo "==> generating smoke fixtures"
  "$REPO/scripts/gen-smoke-fixtures"
fi

# /workspace inside the container: input is the ro fixtures bind-mount,
# working + out are scratch dirs the container creates fresh per run.
mkdir -p "$SCRATCH/working" "$SCRATCH/out"

RUN_ID="smoke-$(date +%Y%m%d-%H%M%S)"
echo "==> running smoke against $IMAGE:$TAG (run_id=$RUN_ID)"
docker run --rm \
  -e DIRT_WAKE_WORD_N_SAMPLES=20 \
  -e DIRT_WAKE_WORD_N_SAMPLES_VAL=10 \
  -e DIRT_WAKE_WORD_STEPS=20 \
  -e DIRT_RUN_ID="$RUN_ID" \
  -v "$FIXTURES:/workspace/input:ro" \
  -v "$SCRATCH/working:/workspace/working" \
  -v "$SCRATCH/out:/workspace/out" \
  "$IMAGE:$TAG"

# Per-run dir under /workspace/out — same layout production uses.
RUN_OUT="$SCRATCH/out/$RUN_ID"
if [ -f "$RUN_OUT/SUCCESS" ] && [ -f "$RUN_OUT/hey_claudia.onnx" ]; then
  size=$(stat -c%s "$RUN_OUT/hey_claudia.onnx")
  echo "==> SMOKE OK (.onnx = ${size} bytes)"
  exit 0
fi

echo "==> SMOKE FAIL" >&2
[ -f "$RUN_OUT/FAILURE" ] && {
  echo "--- $RUN_OUT/FAILURE ---" >&2
  cat "$RUN_OUT/FAILURE" >&2
}
ls -laR "$SCRATCH/out/" >&2
exit 1
