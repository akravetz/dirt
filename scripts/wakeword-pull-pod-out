#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Pull a training pod's `out/<pod_id>/` artifacts from the volume via S3.

Useful when the orchestrator died mid-run (pod kept training, wrote
sentinel, but nothing pulled the .onnx + manifest + report). The same
helper runpod-train uses for its post-sentinel pull, just with manual
pod-id input.

Usage:
  scripts/wakeword-pull-pod-out POD_ID [--dest DIR]

The destination defaults to var/wake-word/models/<datestamp>-<pod_id>/.
"""

from __future__ import annotations

import argparse
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("pod_id")
    parser.add_argument("--dest", type=Path, default=None)
    args = parser.parse_args()

    rp.load_env()
    bucket = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    s3 = rp.s3_client()

    dest = args.dest or (
        rp.repo_root() / "var" / "wake-word" / "models"
        / f"{time.strftime('%Y-%m-%d-%H%M%S')}-{args.pod_id}"
    )
    pulled = rp.pull_artifacts(
        s3,
        bucket=bucket,
        prefix=f"out/{args.pod_id}/",
        dest=dest,
        filenames=rp.TRAINER_ARTIFACTS,
    )

    print(f"\n=== pulled {pulled}/{len(rp.TRAINER_ARTIFACTS)} files → {dest} ===")
    if (dest / "SUCCESS").exists():
        print("training succeeded")
    elif (dest / "FAILURE").exists():
        print("training failed; see FAILURE file for traceback")
    else:
        print("WARN: no SUCCESS or FAILURE sentinel — entrypoint never finished?")
    return 0


if __name__ == "__main__":
    sys.exit(main())
