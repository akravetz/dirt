#!/usr/bin/env bash
# Push the wake-word training kernel to Kaggle, poll until it finishes, pull
# the trained ONNX + tflite artifacts into the current directory.
#
# Prerequisites:
#   - kaggle is installed as a workspace dev dep (`uv add --dev kaggle`)
#   - ~/.kaggle/kaggle.json with a valid API token (chmod 600)
#   - The three datasets referenced in kernel-metadata.json exist in Kaggle.
#
# Usage:
#   scripts/kaggle-train              # push + poll + pull
#   scripts/kaggle-train --push-only  # push, skip polling (check web UI)
#   scripts/kaggle-train --pull-only  # skip push + poll, only pull latest output
#   scripts/kaggle-train --resume     # skip push, poll + pull (use after a manual push or interrupted run)

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
KERNEL_DIR="$REPO_ROOT/apps/wake-word/kaggle"
META="$KERNEL_DIR/kernel-metadata.json"
POLL_INTERVAL=20
OUT_DIR="${KAGGLE_TRAIN_OUT_DIR:-$REPO_ROOT/var/wake-word/models}"

KAGGLE=(uv run --project "$REPO_ROOT" kaggle)
"${KAGGLE[@]}" --version >/dev/null 2>&1 || {
  echo "error: kaggle CLI not available via uv. Run: uv add --dev kaggle" >&2
  exit 1
}

[ -f "$META" ] || { echo "error: missing $META" >&2; exit 1; }

KERNEL_ID=$(python3 -c "import json,sys; print(json.load(open('$META'))['id'])")
echo "kernel: $KERNEL_ID"

mode=${1:-full}

if [ "$mode" != "--pull-only" ] && [ "$mode" != "--resume" ]; then
  # Pre-flight: try to import the library. Most import-class bugs (wrong
  # module path, broken syntax, missing module) fail in <2s. If openwakeword
  # / torch aren't installed locally (default — the [wake-word] extras are
  # heavy), we can only check the structural bits, but that still catches
  # the bug class that crashed v6 + v8.
  echo "==> pre-flight: import dirt_wake_word + run pytest collection"
  PREFLIGHT=$(uv run --project "$REPO_ROOT" python -c "
import sys
sys.path.insert(0, '$REPO_ROOT/apps/wake-word/src')
import importlib
ok = True
try:
    importlib.import_module('dirt_wake_word')
    print('library top-level: OK')
except ImportError as e:
    msg = str(e)
    if any(s in msg for s in ('openwakeword', 'torch', 'numpy', 'audiomentations')):
        print(f'library top-level: deps not installed locally — skipping deeper check ({msg})')
    else:
        print(f'FATAL import: {msg}', file=sys.stderr)
        ok = False
sys.exit(0 if ok else 1)
" 2>&1)
  echo "    $PREFLIGHT"
  case "$PREFLIGHT" in
    *FATAL*)
      echo "error: pre-flight import check failed; fix locally before pushing." >&2
      exit 1
      ;;
  esac

  # Pin the kernel to the current commit. The shim's __DIRT_REPO_SHA_INJECTED_AT_PUSH__
  # sentinel is replaced with the live SHA so the kernel that runs on Kaggle
  # is reproducibly tied to a specific repo state. Source file is restored
  # after push regardless of pass/fail.
  SHA=$(git -C "$REPO_ROOT" rev-parse HEAD)

  # The kernel does `git clone https://github.com/akravetz/dirt && git checkout $SHA`
  # against origin. If $SHA isn't pushed yet, that checkout exits 128 and the
  # kernel dies 5 minutes in for nothing. Verify the SHA is reachable from
  # origin/main before burning a Kaggle slot. v11 ate one of these.
  echo "==> verifying $SHA is on origin/main"
  git -C "$REPO_ROOT" fetch --quiet origin main
  if ! git -C "$REPO_ROOT" merge-base --is-ancestor "$SHA" origin/main; then
    echo "error: HEAD ($SHA) is not on origin/main." >&2
    echo "       Push first (git push origin main) — the kernel clones the public repo," >&2
    echo "       so unpushed commits will fail at \`git checkout\` inside Kaggle." >&2
    exit 1
  fi
  KERNEL_FILE="$KERNEL_DIR/train-hey-claudia.py"
  KERNEL_BACKUP=$(mktemp)
  cp "$KERNEL_FILE" "$KERNEL_BACKUP"
  trap 'cp "$KERNEL_BACKUP" "$KERNEL_FILE"; rm -f "$KERNEL_BACKUP"' EXIT
  sed -i "s|__DIRT_REPO_SHA_INJECTED_AT_PUSH__|$SHA|g" "$KERNEL_FILE"
  echo "==> pushing kernel (pinned to $SHA)"
  "${KAGGLE[@]}" kernels push -p "$KERNEL_DIR"
  # Restore happens via the EXIT trap above.
fi

if [ "$mode" = "--push-only" ]; then
  echo "push complete. Watch progress at https://www.kaggle.com/code/$KERNEL_ID"
  exit 0
fi

if [ "$mode" != "--pull-only" ]; then
  echo "==> polling (every ${POLL_INTERVAL}s; Ctrl-C to stop — kernel keeps running)"
  while true; do
    raw=$("${KAGGLE[@]}" kernels status "$KERNEL_ID" 2>&1 | tail -n 1)
    echo "  $(date +%H:%M:%S) $raw"
    # Status line shape: '<id> has status "KernelWorkerStatus.RUNNING"'.
    # Match against the known terminal enum values, not arbitrary substrings —
    # otherwise a permission-denied message containing "error" trips early-exit.
    case "$raw" in
      *KernelWorkerStatus.COMPLETE*) break ;;
      *KernelWorkerStatus.ERROR*|*KernelWorkerStatus.CANCEL*)
        echo "kernel did not succeed. See https://www.kaggle.com/code/$KERNEL_ID" >&2
        exit 1
        ;;
    esac
    sleep "$POLL_INTERVAL"
  done
fi

echo "==> pulling output -> $OUT_DIR"
mkdir -p "$OUT_DIR"
"${KAGGLE[@]}" kernels output "$KERNEL_ID" -p "$OUT_DIR"
ls -lh "$OUT_DIR"
