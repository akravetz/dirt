#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Push a local directory to the wake-word RunPod Network Volume and update
the volume's MANIFEST.json content hash for that subdir. No pod spawn —
direct S3 API.

Uses `aws s3 sync --delete --size-only` (the AWS CLI) for the diff-and-update,
which sidesteps two RunPod-S3 bugs we'd otherwise have to hand-fix:
- Bulk DeleteObjects returns 307 (sync uses singular DeleteObject)
- ListObjectsV2 paginator leaks ContinuationTokens across prefixes
  (sync's listing is bounded enough not to hit the leak in practice)

Usage:
  scripts/wakeword-volume-bump <slug> <local-dir> [--notes "msg"]
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

from botocore.exceptions import ClientError

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

SLUG_RE = re.compile(r"^[a-z0-9][a-z0-9-]{1,63}$")
INPUT_PREFIX = "input"
MANIFEST_KEY = f"{INPUT_PREFIX}/MANIFEST.json"


def content_hash(local_dir: Path) -> tuple[str, int, int]:
    """sha256 over sorted (relpath, size, sha256(content)) lines."""
    agg = hashlib.sha256()
    total_bytes = 0
    files = sorted(p for p in local_dir.rglob("*") if p.is_file())
    for path in files:
        rel = path.relative_to(local_dir).as_posix()
        size = path.stat().st_size
        h = hashlib.sha256()
        with path.open("rb") as f:
            while chunk := f.read(1 << 20):
                h.update(chunk)
        total_bytes += size
        agg.update(f"{rel}\t{size}\t{h.hexdigest()}\n".encode())
    return agg.hexdigest(), len(files), total_bytes


def aws_s3_upload(*, local_dir: Path, bucket: str, prefix: str) -> None:
    """Upload local_dir → s3://bucket/prefix/ via `aws s3 cp --recursive`.

    NOT `aws s3 sync` — sync needs to list the remote to compute the diff,
    and RunPod's list_objects_v2 paginator returns ContinuationTokens that
    leak across prefix boundaries (server-side bug). cp --recursive walks
    only the source side, so it's immune. Idempotent in outcome (final
    state matches local) but re-uploads every file on each invocation;
    bumps are rare so this is fine.
    """
    dc = os.environ.get("RUNPOD_VOLUME_DATACENTER", "US-IL-1")
    env = os.environ | {
        "AWS_ACCESS_KEY_ID": rp.env("RUNPOD_S3_ACCESS_KEY_ID"),
        "AWS_SECRET_ACCESS_KEY": rp.env("RUNPOD_S3_SECRET_ACCESS_KEY"),
    }
    subprocess.run(
        [
            "aws", "s3", "cp",
            f"{local_dir}/",
            f"s3://{bucket}/{prefix.rstrip('/')}/",
            "--recursive",
            "--region", dc,
            "--endpoint-url", f"https://s3api-{dc.lower()}.runpod.io/",
        ],
        env=env, check=True,
    )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("slug", help="On-volume directory name (e.g. dirt-wakeword-mine).")
    parser.add_argument("local_dir", type=Path)
    parser.add_argument("--notes", default="")
    parser.add_argument(
        "--no-upload", action="store_true",
        help="Skip the S3 upload; hash local + update MANIFEST only. For "
             "static datasets already on the volume that we don't want to "
             "re-upload (e.g. multi-GB feature files).",
    )
    args = parser.parse_args()

    if not SLUG_RE.match(args.slug):
        sys.exit(f"error: slug {args.slug!r} must match {SLUG_RE.pattern}")
    if not args.local_dir.is_dir():
        sys.exit(f"error: {args.local_dir} is not a directory")

    rp.load_env()
    bucket = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    s3 = rp.s3_client()
    prefix = f"{INPUT_PREFIX}/{args.slug}"

    print(f"==> hashing {args.local_dir}")
    digest, file_count, size_bytes = content_hash(args.local_dir)
    print(f"  content_hash=sha256:{digest}  files={file_count}  bytes={size_bytes}")

    if args.no_upload:
        print("==> --no-upload: skipping aws s3 cp; volume bytes presumed identical")
    else:
        print(f"==> aws s3 cp --recursive → s3://{bucket}/{prefix}/")
        aws_s3_upload(local_dir=args.local_dir, bucket=bucket, prefix=prefix)

    print(f"==> updating {MANIFEST_KEY}")
    try:
        manifest = json.loads(s3.get_object(Bucket=bucket, Key=MANIFEST_KEY)["Body"].read())
    except ClientError as exc:
        if exc.response["Error"]["Code"] not in ("NoSuchKey", "404", "InvalidArgument"):
            raise
        manifest = {"schema_version": 1, "datasets": {}}
    bumped_at = datetime.now(UTC).isoformat()
    manifest["updated_at"] = bumped_at
    entry = {
        "content_hash": f"sha256:{digest}",
        "file_count": file_count,
        "size_bytes": size_bytes,
        "bumped_at": bumped_at,
        "notes": args.notes,
    }
    if args.no_upload:
        entry["upload_skipped"] = True
    manifest.setdefault("datasets", {})[args.slug] = entry
    s3.put_object(
        Bucket=bucket, Key=MANIFEST_KEY,
        Body=json.dumps(manifest, indent=2).encode() + b"\n",
        ContentType="application/json",
    )

    mirror = rp.repo_root() / "var" / "wake-word" / "_volume-mirror"
    mirror.mkdir(parents=True, exist_ok=True)
    (mirror / "MANIFEST.json").write_bytes(json.dumps(manifest, indent=2).encode() + b"\n")
    print(f"==> done; MANIFEST mirrored → {mirror / 'MANIFEST.json'}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
