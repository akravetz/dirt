#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""LEGACY — disaster-recovery bootstrap of a RunPod Network Volume from
the (now-retired) Kaggle datasets.

This script is no longer the routine path. As of 2026-04-26 the RunPod
volume is the sole source of truth for training data; the routine
publish verb is `scripts/wakeword-volume-bump`, and the durability
backup is `scripts/wakeword-volume-snapshot` mirroring to
`var/wake-word/_volume-mirror/`. See
`wiki/decisions/2026-04-25-runpod-migration.md` (Update 2026-04-26).

Kept for the rare case of needing to recreate a volume from the Kaggle
mirror (e.g. RunPod loses a region's volume capacity AND the local
mirror is unusable). For the common DR case, restore from the local
mirror — it's faster, doesn't require Kaggle auth, and matches the
authoritative content hashes recorded in MANIFEST.json.

Spawns a small CPU pod with python:3.11-slim, mounts the Network Volume at
/workspace, downloads the four Kaggle datasets to /workspace/input/<slug>/,
writes /workspace/SEED_OK or /workspace/SEED_FAILED on completion, then
sleeps so the orchestrator can SSH-poll for the sentinel.

The container ALWAYS exits 0 (after sleep). RunPod's container runtime
auto-restarts on non-zero exit, which silently burns $/hr on crash loops;
this contract eliminates that class of failure entirely.

Recovery is "skip if dir non-trivially populated, else wipe and
redownload." No clever in-place resume — the partial-zip optimization
already burned us with corrupt zips that wouldn't extract.

Required env (.env):
  RUNPOD_API_KEY              — bearer token
  RUNPOD_NETWORK_VOLUME_ID    — Network Volume to seed (create via console)

Kaggle auth: reads ~/.kaggle/kaggle.json, forwards username+key as env.

Usage:
  scripts/runpod-seed-volume                # idempotent (skip already-present)
  scripts/runpod-seed-volume --reset        # wipe + redownload all four
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
import textwrap
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

# 17 GB features dataset is the long pole, ~30–60 min download + extract.
# 2 h hard cap leaves room for retries / network blips.
MAX_WALL_S = 2 * 60 * 60

SSH_KEY_PATH = Path.home() / ".ssh" / "runpod_ed25519"


def _public_key() -> str:
    pub = SSH_KEY_PATH.with_suffix(".pub")
    if pub.exists():
        return pub.read_text().strip()
    sys.exit(
        f"error: missing SSH public key at {pub}\n"
        "  Generate with: ssh-keygen -t ed25519 -f ~/.ssh/runpod_ed25519 -N ''\n"
        "  Then upload the .pub at https://www.console.runpod.io/user/settings"
    )


def _wait_for_endpoint(
    http, pod_id: str, *, deadline: float, poll_every: int = 5
) -> tuple[str, int]:
    while time.monotonic() < deadline:
        pod = rp.get_pod(http, pod_id)
        ip = (pod.get("publicIp") or "").strip()
        port = (pod.get("portMappings") or {}).get("22")
        if ip and port:
            return ip, int(port)
        time.sleep(poll_every)
    raise TimeoutError(f"pod {pod_id} never published an SSH endpoint")

DATASETS = [
    "akravetz/dirt-wakeword-mine",
    "akravetz/dirt-wakeword-bg",
    "akravetz/dirt-wakeword-features",
    "akravetz/dirt-wakeword-validation",
]

SEED_OK = "/workspace/SEED_OK"
SEED_FAILED = "/workspace/SEED_FAILED"


def _load_kaggle_creds() -> tuple[str, str]:
    path = Path.home() / ".kaggle" / "kaggle.json"
    if not path.exists():
        sys.exit(
            f"error: missing kaggle credentials at {path}\n"
            "  Create at https://www.kaggle.com/settings/account → API → "
            "Create New API Token, save to ~/.kaggle/kaggle.json (chmod 600)."
        )
    blob = json.loads(path.read_text())
    return blob["username"], blob["key"]


def _build_seed_command(*, reset: bool) -> str:
    """Bash that runs in the seed pod.

    Three contracts, in order of importance:
      1. ALWAYS exits 0 (RunPod auto-restarts on non-zero).
      2. Writes /workspace/SEED_OK on success or /workspace/SEED_FAILED on
         failure (with the failing log line). Sole signal to orchestrator.
      3. After writing the sentinel, blocks on `sleep infinity` so sshd
         stays up for the orchestrator to read the sentinel via SSH.
    """
    slugs = " ".join(DATASETS)
    reset_block = (
        "echo '==> --reset: wiping /workspace/input/'\n"
        "        rm -rf /workspace/input/*"
        if reset
        else "echo '(skip-if-present mode; pass --reset to wipe and redownload)'"
    )
    return textwrap.dedent(f"""\
        #!/usr/bin/env bash
        # Tooling + sshd setup OUTSIDE the err-trap so an apt failure still
        # leaves us with a debuggable container.
        set -uo pipefail
        apt-get update -q && apt-get install -y -q openssh-server >/dev/null
        pip install --quiet kaggle
        mkdir -p /run/sshd /root/.ssh
        if [ -n "${{PUBLIC_KEY:-}}" ]; then
          echo "$PUBLIC_KEY" >> /root/.ssh/authorized_keys
          chmod 700 /root/.ssh && chmod 600 /root/.ssh/authorized_keys
        fi
        /usr/sbin/sshd

        run_seed() {{
          set -e
          {reset_block}
          mkdir -p /workspace/input && cd /workspace/input
          for slug in {slugs}; do
            name="${{slug##*/}}"
            size=$(du -sm "$name" 2>/dev/null | cut -f1 || echo 0)
            if [ "$size" -gt 50 ]; then
              echo "==> $name: already $size MB, skipping"
              continue
            fi
            echo "==> $name: downloading"
            # Wipe before download — kaggle CLI fails ungracefully on a
            # corrupt partial download. Cheaper to redo than to diagnose.
            rm -rf "$name"
            kaggle datasets download -d "$slug" --unzip -p "$name"
          done
        }}

        if run_seed > /workspace/seed.log 2>&1; then
          tail -20 /workspace/seed.log
          du -sh /workspace/input/*
          touch {SEED_OK}
          echo "=== SEED_OK ==="
        else
          rc=$?
          echo "=== SEED FAILED (exit $rc) ===" >&2
          tail -50 /workspace/seed.log >&2
          {{ echo "exit=$rc"; tail -50 /workspace/seed.log; }} > {SEED_FAILED}
        fi

        echo "(work done; sleeping for orchestrator)"
        exec sleep infinity
        """)


def _ssh_check_sentinel(ip: str, port: int) -> str | None:
    """SSH and check for SEED_OK / SEED_FAILED. None = neither yet."""
    try:
        result = subprocess.run(
            [
                "ssh",
                "-i", str(SSH_KEY_PATH),
                "-o", "StrictHostKeyChecking=accept-new",
                "-o", "UserKnownHostsFile=/dev/null",
                "-o", "ConnectTimeout=10",
                "-p", str(port),
                f"root@{ip}",
                f"if [ -f {SEED_OK} ]; then echo OK; "
                f"elif [ -f {SEED_FAILED} ]; then echo FAILED; cat {SEED_FAILED}; fi",
            ],
            capture_output=True, text=True, timeout=20,
        )
        out = result.stdout.strip()
        if out.startswith("OK"):
            return "OK"
        if out.startswith("FAILED"):
            print(out, file=sys.stderr)
            return "FAILED"
        return None
    except subprocess.SubprocessError:
        return None


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--reset",
        action="store_true",
        help="Wipe /workspace/input/* before download — for clean recovery.",
    )
    args = parser.parse_args()

    rp.load_env()
    api_key = rp.env("RUNPOD_API_KEY")
    network_volume_id = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    kaggle_user, kaggle_key = _load_kaggle_creds()
    pub_key = _public_key()

    body = {
        "name": f"wakeword-seed-{time.strftime('%Y%m%d-%H%M%S')}",
        "networkVolumeId": network_volume_id,
        "volumeMountPath": "/workspace",
        "ports": ["22/tcp"],
        "supportPublicIp": True,
        "cloudType": "SECURE",
        "interruptible": False,
        "imageName": "python:3.11-slim",
        "computeType": "CPU",
        "vcpuCount": 4,
        "minRAMPerGPU": 8,
        "containerDiskInGb": 20,
        "dockerStartCmd": ["bash", "-c", _build_seed_command(reset=args.reset)],
        "env": {
            "PUBLIC_KEY": pub_key,
            "KAGGLE_USERNAME": kaggle_user,
            "KAGGLE_KEY": kaggle_key,
            "PYTHONUNBUFFERED": "1",
        },
    }

    http = rp.client(api_key)
    pod_id = rp.create_pod(http, body)
    print(f"created seed pod {pod_id}")
    print("  inspect logs at https://www.console.runpod.io/pods")

    deadline = time.monotonic() + MAX_WALL_S
    sentinel: str | None = None

    with rp.leased_pod(http, pod_id):
        ip, port = _wait_for_endpoint(http, pod_id, deadline=deadline)
        print(f"pod reachable at {ip}:{port}; polling for sentinel")

        while time.monotonic() < deadline:
            sentinel = _ssh_check_sentinel(ip, port)
            if sentinel:
                print(f"  {time.strftime('%H:%M:%S')} sentinel={sentinel}")
                break
            print(f"  {time.strftime('%H:%M:%S')} (waiting)")
            time.sleep(30)

    if sentinel == "OK":
        print("=== seed complete; volume is ready for trainer pods ===")
        return 0
    if sentinel == "FAILED":
        print("=== seed FAILED — see traceback above ===", file=sys.stderr)
        return 1
    print(f"=== seed timed out after {MAX_WALL_S}s ===", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
