#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""One-time seed of a RunPod Network Volume with Kaggle datasets.

Spawns a small CPU pod with python:3.11-slim, mounts the Network Volume at
/workspace, pip-installs the kaggle CLI, and downloads four datasets to
/workspace/input/<slug>/. The pod exits when the downloads complete; the
data persists on the Network Volume after `DELETE /pods/{id}`.

Run once per fresh Network Volume — re-running is safe but wastes ~10 min.

Required env (load via `.env`):
  RUNPOD_API_KEY              — bearer token
  RUNPOD_NETWORK_VOLUME_ID    — Network Volume to seed (create via the console)

Kaggle auth: reads ~/.kaggle/kaggle.json on the local machine (chmod 600)
and forwards username/key to the pod as KAGGLE_USERNAME / KAGGLE_KEY env
vars. The pod never gets the json file directly.

Usage:
  scripts/runpod-seed-volume                # download all four datasets
  scripts/runpod-seed-volume --force        # redownload (--unzip overwrites)
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import textwrap
import time
from pathlib import Path

import httpx
from dotenv import load_dotenv

REST_BASE = "https://rest.runpod.io/v1"
POLL_EVERY_S = 30
# 17 GB features dataset's download + unzip is the long pole, ~60-90 min
# on RunPod's outbound. 2.5 h gives runway for retries.
MAX_WALL_S = int(2.5 * 60 * 60)

DATASETS = [
    "akravetz/dirt-wakeword-mine",
    "akravetz/dirt-wakeword-bg",
    "akravetz/dirt-wakeword-features",
    "akravetz/dirt-wakeword-validation",
]


def _env(name: str, *, required: bool = True) -> str:
    v = os.environ.get(name, "").strip()
    if required and not v:
        sys.exit(f"error: {name} not set in environment (.env)")
    return v


def _load_kaggle_creds() -> tuple[str, str]:
    path = Path.home() / ".kaggle" / "kaggle.json"
    if not path.exists():
        sys.exit(
            f"error: missing kaggle credentials at {path}\n"
            "  Generate at https://www.kaggle.com/settings/account → Create New API Token,\n"
            "  then place at ~/.kaggle/kaggle.json (chmod 600)."
        )
    blob = json.loads(path.read_text())
    return blob["username"], blob["key"]


def _build_seed_command(force: bool) -> str:
    """Bash that runs in the seed pod. Kept here as a textwrap-dedented heredoc
    instead of Python string concatenation so it reads as actual bash.

    python:3.11-slim ships nothing useful — sshd, unzip, and the kaggle CLI
    all get installed at the top. The for-loop has three branches:
      partial (zip present)       — re-extract in place, no re-download
      complete (>50 MB, no zip)   — skip
      empty/new                   — kaggle download + unzip
    --force routes through to kaggle CLI, which makes the empty/new branch
    overwrite. The partial branch always re-extracts regardless of --force
    since a leftover zip is a strong signal of an interrupted prior run.
    """
    force_flag = " --force" if force else ""
    slugs = " ".join(DATASETS)
    return textwrap.dedent(f"""\
        set -euo pipefail

        apt-get update -q && apt-get install -y -q openssh-server unzip >/dev/null
        pip install --quiet kaggle

        # SSH for live debugging if a download stalls.
        mkdir -p /run/sshd /root/.ssh
        if [ -n "${{PUBLIC_KEY:-}}" ]; then
          echo "$PUBLIC_KEY" >> /root/.ssh/authorized_keys
          chmod 700 /root/.ssh && chmod 600 /root/.ssh/authorized_keys
        fi
        /usr/sbin/sshd

        mkdir -p /workspace/input && cd /workspace/input
        for slug in {slugs}; do
          name="${{slug##*/}}"
          zip="$name/$name.zip"

          if [ -f "$zip" ]; then
            echo "==> $name: re-extracting existing zip"
            find "$name" -mindepth 1 -not -name "*.zip" -delete
            (cd "$name" && unzip -q -o "$name.zip" && rm -f "$name.zip")
            continue
          fi

          size=$(du -sm "$name" 2>/dev/null | cut -f1 || echo 0)
          if [ "$size" -gt 50 ]; then
            echo "==> $name: already $size MB, skipping"
            continue
          fi

          echo "==> $name: downloading"
          kaggle datasets download -d "$slug" --unzip -p "$name"{force_flag}
        done

        echo "==> seed complete"
        ls -la /workspace/input
        du -sh /workspace/input/*
        """)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--force",
        action="store_true",
        help="Pass --force to kaggle CLI to redownload existing datasets.",
    )
    args = parser.parse_args()

    repo_root = Path(__file__).resolve().parent.parent
    load_dotenv(repo_root / ".env")
    api_key = _env("RUNPOD_API_KEY")
    network_volume_id = _env("RUNPOD_NETWORK_VOLUME_ID")
    kaggle_user, kaggle_key = _load_kaggle_creds()

    client = httpx.Client(
        base_url=REST_BASE,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        timeout=30.0,
    )

    pub_key_path = Path.home() / ".ssh" / "runpod_ed25519.pub"
    public_key = pub_key_path.read_text().strip() if pub_key_path.exists() else ""

    body = {
        "name": f"wakeword-seed-{time.strftime('%Y%m%d-%H%M%S')}",
        "imageName": "python:3.11-slim",
        "computeType": "CPU",
        "vcpuCount": 4,
        "minRAMPerGPU": 8,
        "containerDiskInGb": 20,
        "networkVolumeId": network_volume_id,
        "volumeMountPath": "/workspace",
        "ports": ["22/tcp"],
        "supportPublicIp": True,
        "cloudType": "SECURE",
        "interruptible": False,
        "env": {
            "KAGGLE_USERNAME": kaggle_user,
            "KAGGLE_KEY": kaggle_key,
            "PUBLIC_KEY": public_key,
            "PYTHONUNBUFFERED": "1",
        },
        "dockerStartCmd": ["bash", "-c", _build_seed_command(args.force)],
    }

    r = client.post("/pods", json=body)
    if r.status_code >= 400:
        sys.exit(f"error: POST /pods → {r.status_code}: {r.text}")
    pod_id = r.json()["id"]
    print(f"created seed pod {pod_id}")
    print("  inspect logs at https://www.console.runpod.io/pods")

    deadline = time.monotonic() + MAX_WALL_S
    final_status = ""
    try:
        while time.monotonic() < deadline:
            pod = client.get(f"/pods/{pod_id}").json()
            status = pod.get("desiredStatus", "")
            ts = time.strftime("%H:%M:%S")
            print(f"  {ts} pod {pod_id} status={status}")
            if status in ("EXITED", "TERMINATED"):
                final_status = status
                break
            time.sleep(POLL_EVERY_S)
        else:
            sys.exit(f"timeout: pod {pod_id} did not finish within {MAX_WALL_S}s")
    finally:
        try:
            client.delete(f"/pods/{pod_id}").raise_for_status()
            print(f"deleted pod {pod_id}")
        except Exception as exc:
            print(f"WARN: pod {pod_id} delete failed: {exc!r}", file=sys.stderr)

    if final_status != "EXITED":
        sys.exit(f"seed pod did not reach EXITED (was: {final_status})")
    print("=== seed complete; volume is ready for trainer pods ===")
    return 0


if __name__ == "__main__":
    sys.exit(main())
