#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""One-time seed of a RunPod Network Volume with the four Kaggle datasets.

Spawns a small CPU pod with python:3.11-slim, mounts the Network Volume at
/workspace, downloads the four datasets to /workspace/input/<slug>/. Pod
exits when the downloads complete; the data persists on the Network Volume
after `DELETE /pods/{id}`.

Run once per fresh Network Volume — re-running is idempotent (skips
already-extracted slugs; resumes a partial unzip in place without
re-downloading the .zip).

Required env (.env):
  RUNPOD_API_KEY              — bearer token
  RUNPOD_NETWORK_VOLUME_ID    — Network Volume to seed (create via console)

Kaggle auth: reads ~/.kaggle/kaggle.json on the local machine and forwards
username/key to the pod as KAGGLE_USERNAME / KAGGLE_KEY env vars.

Usage:
  scripts/runpod-seed-volume                # idempotent fill
  scripts/runpod-seed-volume --force        # redownload (--force on kaggle CLI)
"""

from __future__ import annotations

import argparse
import json
import sys
import textwrap
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

# 17 GB features dataset's download + unzip is the long pole, ~60–90 min on
# RunPod's outbound. 2.5 h gives runway for retries.
MAX_WALL_S = int(2.5 * 60 * 60)

DATASETS = [
    "akravetz/dirt-wakeword-mine",
    "akravetz/dirt-wakeword-bg",
    "akravetz/dirt-wakeword-features",
    "akravetz/dirt-wakeword-validation",
]


def _load_kaggle_creds() -> tuple[str, str]:
    path = Path.home() / ".kaggle" / "kaggle.json"
    if not path.exists():
        sys.exit(
            f"error: missing kaggle credentials at {path}\n"
            "  Create at https://www.kaggle.com/settings/account → API → "
            "Create New API Token, save to ~/.kaggle/kaggle.json (chmod 600)."
        )
    blob = json.loads(path.read_text())
    return blob["username"], blob["key"]


def _build_seed_command(*, force: bool) -> str:
    """Bash that runs in the seed pod. textwrap.dedent + heredoc so the body
    reads as actual bash; only `force` and slug list interpolate.

    python:3.11-slim ships nothing useful — sshd, unzip, and the kaggle CLI
    all get installed at the top. The for-loop has three branches per slug:
      partial (zip present)       — re-extract in place, no re-download
      complete (>50 MB, no zip)   — skip
      empty/new                   — kaggle download + unzip
    --force routes through to kaggle CLI, which makes the empty/new branch
    overwrite. The partial branch always re-extracts regardless of --force
    since a leftover zip is a strong signal of an interrupted prior run.
    """
    force_flag = " --force" if force else ""
    slugs = " ".join(DATASETS)
    return textwrap.dedent(f"""\
        set -euo pipefail

        apt-get update -q && apt-get install -y -q openssh-server unzip >/dev/null
        pip install --quiet kaggle

        # SSH for live debugging if a download stalls.
        mkdir -p /run/sshd /root/.ssh
        if [ -n "${{PUBLIC_KEY:-}}" ]; then
          echo "$PUBLIC_KEY" >> /root/.ssh/authorized_keys
          chmod 700 /root/.ssh && chmod 600 /root/.ssh/authorized_keys
        fi
        /usr/sbin/sshd

        mkdir -p /workspace/input && cd /workspace/input
        for slug in {slugs}; do
          name="${{slug##*/}}"
          zip="$name/$name.zip"

          if [ -f "$zip" ]; then
            echo "==> $name: re-extracting existing zip"
            find "$name" -mindepth 1 -not -name "*.zip" -delete
            (cd "$name" && unzip -q -o "$name.zip" && rm -f "$name.zip")
            continue
          fi

          size=$(du -sm "$name" 2>/dev/null | cut -f1 || echo 0)
          if [ "$size" -gt 50 ]; then
            echo "==> $name: already $size MB, skipping"
            continue
          fi

          echo "==> $name: downloading"
          kaggle datasets download -d "$slug" --unzip -p "$name"{force_flag}
        done

        echo "==> seed complete"
        ls -la /workspace/input
        du -sh /workspace/input/*
        """)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--force",
        action="store_true",
        help="Pass --force to kaggle CLI to redownload existing datasets.",
    )
    args = parser.parse_args()

    rp.load_env()
    api_key = rp.env("RUNPOD_API_KEY")
    network_volume_id = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    kaggle_user, kaggle_key = _load_kaggle_creds()
    pub_key = rp.public_key(required=False)

    body = rp.common_pod_body(
        name=f"wakeword-seed-{time.strftime('%Y%m%d-%H%M%S')}",
        network_volume_id=network_volume_id,
        public_key=pub_key,
    ) | {
        "imageName": "python:3.11-slim",
        "computeType": "CPU",
        "vcpuCount": 4,
        "minRAMPerGPU": 8,
        "containerDiskInGb": 20,
        "dockerStartCmd": ["bash", "-c", _build_seed_command(force=args.force)],
    }
    body["env"] |= {
        "KAGGLE_USERNAME": kaggle_user,
        "KAGGLE_KEY": kaggle_key,
        "PYTHONUNBUFFERED": "1",
    }

    http = rp.client(api_key)
    pod_id = rp.create_pod(http, body)
    print(f"created seed pod {pod_id}")
    print("  inspect logs at https://www.console.runpod.io/pods")

    deadline = time.monotonic() + MAX_WALL_S
    with rp.leased_pod(http, pod_id):
        status = rp.wait_for_exit(http, pod_id, deadline=deadline, poll_every=30)

    if status != "EXITED":
        sys.exit(f"seed pod ended in {status}, not EXITED")
    print("=== seed complete; volume is ready for trainer pods ===")
    return 0


if __name__ == "__main__":
    sys.exit(main())
