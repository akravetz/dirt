#!/usr/bin/env bash
# Stage the two heavy Kaggle datasets for the wake-word training kernel.
# Run once; re-run only if upstream sources or the audio prep recipe change.
#
# Output layout (ready for `kaggle datasets create -p <dir> [--dir-mode zip]`):
#
#   $FEAT/                                      (~4 GB)
#     ├── dataset-metadata.json
#     ├── openwakeword_features_ACAV100M_2000_hrs_16bit.npy
#     └── validation_set_features.npy
#
#   $BG/                                        (~1.2 GB)
#     ├── dataset-metadata.json
#     ├── audioset_16k/*.wav   (1000 clips from agkphysics/AudioSet bal_train/00.parquet)
#     └── fma/*.wav            (~120 clips ≈ 1 hour, from benjamin-paine/free-music-archive-small)
#
# Both corpora are pulled via direct parquet download + pyarrow + soundfile —
# this bypasses HF `datasets`/`torchcodec` entirely. Upstream openwakeword's
# canonical notebook still references `rudraml/fma`, which is loading-script-
# based and incompatible with current `datasets` (>=4.0 dropped script support).
# `benjamin-paine/free-music-archive-small` is the parquet mirror.
#
# Idempotent: completed downloads + conversions are skipped on rerun.
# Override staging dirs with KAGGLE_FEATURES_DIR / KAGGLE_BG_DIR env vars.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
META_DIR="$REPO_ROOT/apps/wake-word/kaggle/datasets"
FEAT="${KAGGLE_FEATURES_DIR:-/tmp/dirt-wakeword-features}"
BG="${KAGGLE_BG_DIR:-/tmp/dirt-wakeword-bg}"

command -v wget >/dev/null || { echo "error: wget not installed" >&2; exit 1; }
command -v tar  >/dev/null || { echo "error: tar not installed" >&2; exit 1; }
if ! command -v ffmpeg >/dev/null; then
  echo "warning: ffmpeg not on PATH — HuggingFace datasets needs it to decode mp3 (FMA)." >&2
  echo "         apt: sudo apt install ffmpeg" >&2
fi

mkdir -p "$FEAT" "$BG"
cp "$META_DIR/dirt-wakeword-features/dataset-metadata.json" "$FEAT/"
cp "$META_DIR/dirt-wakeword-bg/dataset-metadata.json" "$BG/"

# ---------------------------------------------------------------------------
# Features dataset — two .npy files from HuggingFace, no conversion needed
# ---------------------------------------------------------------------------

echo "==> features: downloading .npy files (~4 GB total)"
HF_FEAT=https://huggingface.co/datasets/davidscripka/openwakeword_features/resolve/main
wget -c "$HF_FEAT/openwakeword_features_ACAV100M_2000_hrs_16bit.npy" \
     -O "$FEAT/openwakeword_features_ACAV100M_2000_hrs_16bit.npy"
wget -c "$HF_FEAT/validation_set_features.npy" \
     -O "$FEAT/validation_set_features.npy"

# ---------------------------------------------------------------------------
# Background dataset — AudioSet shard + FMA-small, both downsampled to 16k WAV
# ---------------------------------------------------------------------------

echo "==> backgrounds: AudioSet (~680 MB) + FMA-small shard (~510 MB) — direct parquet"

# Bypass HuggingFace `datasets`/`torchcodec` entirely. Both corpora have audio
# embedded as bytes in their parquet rows — pyarrow + soundfile decode directly.
# Cache parquets in a sibling dir so they don't end up in the kaggle upload.
PARQUET_CACHE="$(dirname "$BG")/parquet-cache"
mkdir -p "$PARQUET_CACHE"
AUDIOSET_PARQUET="$PARQUET_CACHE/audioset_bal_train_00.parquet"
FMA_PARQUET="$PARQUET_CACHE/fma_small_train_00.parquet"

wget -c "https://huggingface.co/datasets/agkphysics/AudioSet/resolve/main/data/bal_train/00.parquet" \
     -O "$AUDIOSET_PARQUET"
wget -c "https://huggingface.co/datasets/benjamin-paine/free-music-archive-small/resolve/main/data/train-00000-of-00015.parquet" \
     -O "$FMA_PARQUET"

uv run --no-project \
  --with pyarrow --with soundfile --with scipy --with numpy --with tqdm \
  python - "$BG" "$AUDIOSET_PARQUET" "$FMA_PARQUET" <<'PY'
import io
import sys
from math import gcd
from pathlib import Path

import numpy as np
import pyarrow.parquet as pq
import scipy.io.wavfile
import scipy.signal
import soundfile as sf
from tqdm import tqdm

bg, audioset_parquet, fma_parquet = (Path(p) for p in sys.argv[1:4])
TARGET_SR = 16000


def to_16k_mono(audio_bytes: bytes) -> np.ndarray | None:
    if not audio_bytes:
        return None
    arr, sr = sf.read(io.BytesIO(audio_bytes), dtype="float32")
    if arr.ndim > 1:
        arr = arr.mean(axis=1)
    if sr != TARGET_SR:
        g = gcd(sr, TARGET_SR)
        arr = scipy.signal.resample_poly(arr, TARGET_SR // g, sr // g)
    return np.clip(arr * 32767, -32768, 32767).astype(np.int16)


def stage(name: str, parquet_path: Path, out_subdir: str, n_clips: int,
          id_col: str | None = None, prefix: str = "clip") -> None:
    out = bg / out_subdir
    out.mkdir(exist_ok=True)
    if any(out.iterdir()):
        print(f"{out_subdir} already has files; skipping (delete to re-stage)", flush=True)
        return
    print(f"==> {name}: reading {parquet_path}", flush=True)
    cols = ["audio"] + ([id_col] if id_col else [])
    rows = pq.read_table(parquet_path, columns=cols).to_pylist()
    print(f"  {len(rows)} rows in parquet; converting first {n_clips}", flush=True)
    written = 0
    for i, rec in enumerate(tqdm(rows[:n_clips])):
        pcm16 = to_16k_mono(rec["audio"]["bytes"])
        if pcm16 is None:
            continue
        stem = str(rec[id_col]) if id_col else f"{prefix}_{i:05d}"
        scipy.io.wavfile.write(out / f"{stem}.wav", TARGET_SR, pcm16)
        written += 1
    print(f"wrote {written} clips -> {out}", flush=True)


stage("AudioSet", audioset_parquet, "audioset_16k", 500, id_col="video_id")
stage("FMA-small", fma_parquet, "fma", 120, prefix="fma")
PY

# ---------------------------------------------------------------------------

echo
echo "==> staging complete."
echo
echo "Push to Kaggle with:"
echo "    cd $FEAT && uv run kaggle datasets create -p ."
echo "    cd $BG   && uv run kaggle datasets create -p . --dir-mode zip"
echo
echo "(Re-uploads should use 'datasets version -m \"<message>\"' in place of 'create'.)"
