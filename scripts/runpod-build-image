#!/usr/bin/env bash
# Build + smoke + push the wake-word trainer image to GHCR.
#
# Prereqs:
#   - Docker daemon running locally (with buildx for linux/amd64 cross-build).
#   - `gh auth token` works AND grants write:packages, OR you've already
#     `docker login ghcr.io` with a PAT that has write:packages scope.
#
# Three steps, in order, each blocking the next:
#   1. buildx build → tag locally (always loaded, even when pushing)
#   2. scripts/smoke-trainer-image → tiny end-to-end run against fixtures
#   3. push to GHCR (skipped on --no-push or --skip-smoke-and-push)
#
# Usage:
#   scripts/runpod-build-image                       # build + smoke + push
#   scripts/runpod-build-image v1                    # tag :v1
#   scripts/runpod-build-image latest --no-push      # build + smoke, skip push
#   scripts/runpod-build-image latest --skip-smoke   # build + push without smoke (debug only)

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
GHCR_OWNER="${GHCR_OWNER:-akravetz}"
IMAGE="ghcr.io/${GHCR_OWNER}/dirt-wake-word-trainer"
TAG="${1:-latest}"
NO_PUSH=0
SKIP_SMOKE=0
case "${2:-}" in
  --no-push)     NO_PUSH=1 ;;
  --skip-smoke)  SKIP_SMOKE=1 ;;
esac

cd "$REPO_ROOT/apps/wake-word"

# Bake the git SHA into the image (DIRT_GIT_SHA build-arg → ENV) so the
# trainer can stamp it into run-manifest.json. When pushing, the build
# context (apps/wake-word/) must be clean AND HEAD must be on origin/main
# — otherwise the recorded SHA either misrepresents the image contents
# or is unreachable, breaking reproducibility. Guards the bug class v11
# burned us on (unpushed SHA, kernel git checkout failed).
#
# Scoped to apps/wake-word/ rather than the whole repo — uncommitted
# changes elsewhere (e.g. wiki notes, an in-flight PR in another app)
# don't affect the image content and shouldn't block a wake-word push.
# On --no-push we allow dirty/unpushed since the image stays local.
GIT_SHA=$(git -C "$REPO_ROOT" rev-parse HEAD)
if [ "$NO_PUSH" != "1" ]; then
  if ! git -C "$REPO_ROOT" diff-index --quiet HEAD -- apps/wake-word/; then
    echo "error: apps/wake-word/ has uncommitted changes; commit or pass --no-push" >&2
    git -C "$REPO_ROOT" status --short -- apps/wake-word/ >&2
    exit 1
  fi
  git -C "$REPO_ROOT" fetch origin main --quiet
  if ! git -C "$REPO_ROOT" merge-base --is-ancestor "$GIT_SHA" origin/main; then
    echo "error: HEAD ($GIT_SHA) is not on origin/main; push first or pass --no-push" >&2
    exit 1
  fi
fi
echo "==> baking DIRT_GIT_SHA=$GIT_SHA"

# GHCR login (only matters for the push step but cheap to do up-front).
if command -v gh >/dev/null 2>&1 && gh auth token >/dev/null 2>&1; then
  gh auth token | docker login ghcr.io -u "$GHCR_OWNER" --password-stdin
fi

# Build, always --load so the local daemon has the tag available for smoke.
echo "==> docker buildx build linux/amd64 -> $IMAGE:$TAG"
docker buildx build \
  --platform linux/amd64 \
  --build-arg "DIRT_GIT_SHA=$GIT_SHA" \
  -f docker/Dockerfile \
  -t "$IMAGE:$TAG" \
  --load \
  .

# Smoke. Blocks push on failure — saves a $3 H100 round-trip per regression.
if [ "$SKIP_SMOKE" = "1" ]; then
  echo "==> --skip-smoke set; SKIPPING smoke (debug only)"
else
  echo "==> running end-to-end smoke against $IMAGE:$TAG"
  "$REPO_ROOT/scripts/smoke-trainer-image" "$TAG"
fi

if [ "$NO_PUSH" = "1" ]; then
  echo "built + smoked (--no-push); image tagged $IMAGE:$TAG locally"
  exit 0
fi

echo "==> docker push $IMAGE:$TAG"
docker push "$IMAGE:$TAG"
echo "pushed $IMAGE:$TAG"
