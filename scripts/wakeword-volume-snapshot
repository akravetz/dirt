#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Mirror the wake-word RunPod Network Volume to a local backup. No pod
spawn — direct S3 API.

Volume loss = data loss now that Kaggle is retired. Run periodically.

Usage:
  scripts/wakeword-volume-snapshot                          # full mirror
  scripts/wakeword-volume-snapshot --prefix input/MANIFEST  # only one path
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--dest", type=Path, default=None,
        help="Local destination (default: var/wake-word/_volume-mirror/).",
    )
    parser.add_argument(
        "--prefix", default="",
        help="S3 prefix to mirror (default: entire bucket).",
    )
    args = parser.parse_args()

    rp.load_env()
    bucket = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    dest = args.dest or (rp.repo_root() / "var" / "wake-word" / "_volume-mirror")

    print(f"==> mirroring s3://{bucket}/{args.prefix} → {dest}")
    s3 = rp.s3_client()
    n = rp.s3_download_prefix(s3, bucket=bucket, prefix=args.prefix, local_dest=dest)
    print(f"==> done; {n} files mirrored")
    return 0


if __name__ == "__main__":
    sys.exit(main())
