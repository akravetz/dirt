#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Mirror the wake-word RunPod Network Volume to a local backup via
`aws s3 sync`. Use this when you want a local disaster-recovery copy.

Usage:
  scripts/wakeword-volume-snapshot                          # full mirror
  scripts/wakeword-volume-snapshot --prefix input/MANIFEST.json
"""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--dest", type=Path, default=None)
    parser.add_argument("--prefix", default="")
    args = parser.parse_args()

    rp.load_env()
    bucket = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    dest = args.dest or (rp.repo_root() / "var" / "wake-word" / "_volume-mirror")
    dest.mkdir(parents=True, exist_ok=True)

    dc = os.environ.get("RUNPOD_VOLUME_DATACENTER", "US-IL-1")
    prefix = args.prefix.lstrip("/")
    src = f"s3://{bucket}/{prefix}" if prefix else f"s3://{bucket}/"
    print(f"==> aws s3 sync {src} → {dest}")

    env = os.environ | {
        "AWS_ACCESS_KEY_ID": rp.env("RUNPOD_S3_ACCESS_KEY_ID"),
        "AWS_SECRET_ACCESS_KEY": rp.env("RUNPOD_S3_SECRET_ACCESS_KEY"),
    }
    subprocess.run(
        [
            "aws", "s3", "sync", src, str(dest),
            "--size-only",
            "--region", dc,
            "--endpoint-url", f"https://s3api-{dc.lower()}.runpod.io/",
        ],
        env=env, check=True,
    )
    print(f"==> done → {dest}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
