#!/usr/bin/env bash
# Deploy the hosted Dirt control plane through the supported Railway flow.
#
# The script intentionally applies cloud Atlas migrations before uploading app
# code. It never prints .env.prod values; keep xtrace disabled when running it.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ENV_FILE="${DIRT_CONTROL_PLANE_ENV_FILE:-$ROOT_DIR/.env.prod}"
BASE_ENV_FILE="${DIRT_CONTROL_PLANE_BASE_ENV_FILE:-$ROOT_DIR/.env}"

usage() {
    cat <<'EOF'
Usage: scripts/deploy-control-plane [--skip-smoke]

Loads .env first and .env.prod second by default, applies cloud Atlas
migrations, deploys apps/control-plane to Railway service control-plane-api,
deploys web-ui to Railway service web-ui, then runs public smoke checks.

Set DIRT_CONTROL_PLANE_ENV_FILE=/path/to/env to use a different ignored env file.
Set DIRT_CONTROL_PLANE_BASE_ENV_FILE=/path/to/env to override the base .env.
EOF
}

SKIP_SMOKE=0
while [ "$#" -gt 0 ]; do
    case "$1" in
        --skip-smoke)
            SKIP_SMOKE=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "ERROR: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [ -f "$BASE_ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$BASE_ENV_FILE"
    set +a
fi

if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
fi

require_cmd() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "ERROR: required command not found: $1" >&2
        exit 1
    fi
}

require_env() {
    local name="$1"
    if [ -z "${!name:-}" ]; then
        echo "ERROR: required environment variable is unset: $name" >&2
        exit 1
    fi
}

wait_for_http() {
    local label="$1"
    local url="$2"
    local attempts="${DIRT_CONTROL_PLANE_SMOKE_ATTEMPTS:-180}"
    local delay="${DIRT_CONTROL_PLANE_SMOKE_DELAY_S:-5}"

    echo "Checking $label..."
    for attempt in $(seq 1 "$attempts"); do
        if curl -fsS "$url" >/dev/null 2>&1; then
            echo "$label is reachable."
            return 0
        fi
        if [ "$attempt" -eq "$attempts" ]; then
            break
        fi
        sleep "$delay"
    done

    echo "ERROR: $label did not become reachable at $url" >&2
    return 1
}

sync_railway_variable_from_env() {
    local service_id="$1"
    local name="$2"

    if [ -z "${!name:-}" ]; then
        return 0
    fi

    printf "%s" "${!name}" | railway variable set "$name" \
        --stdin \
        --skip-deploys \
        --service "$service_id" \
        --environment "$RAILWAY_ENVIRONMENT" \
        >/dev/null
}

sync_required_railway_variable_from_env() {
    local service_id="$1"
    local name="$2"

    require_env "$name"
    sync_railway_variable_from_env "$service_id" "$name"
}

require_cmd atlas
require_cmd railway
require_cmd curl
require_cmd uv

require_env RAILWAY_PROJECT_ID
require_env RAILWAY_ENVIRONMENT
require_env RAILWAY_CONTROL_PLANE_API_SERVICE_ID
require_env RAILWAY_WEB_UI_SERVICE_ID
require_env RAILWAY_POSTGRES_SERVICE_ID
require_env DIRT_CLOUD_API_BASE_URL
require_env DIRT_CLOUD_UI_BASE_URL

if [ -z "${DIRT_CLOUD_DATABASE_URL:-}" ]; then
    DIRT_CLOUD_DATABASE_URL="$(
        railway variable list \
            --service "$RAILWAY_POSTGRES_SERVICE_ID" \
            --environment "$RAILWAY_ENVIRONMENT" \
            --json \
            | uv run python -c 'import json, sys; data = json.load(sys.stdin); print(data.get("DATABASE_PUBLIC_URL") or "")'
    )"
    export DIRT_CLOUD_DATABASE_URL
fi
require_env DIRT_CLOUD_DATABASE_URL

cd "$ROOT_DIR"

echo "Syncing Railway service variables..."
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_ADMIN_USERNAME
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_ADMIN_PASSWORD_HASH
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_SESSION_SECRET
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_GATEWAY_TOKEN_SHA256
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_ALLOWED_ORIGINS
sync_required_railway_variable_from_env \
    "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" DIRT_CLOUD_UI_BASE_URL
for name in \
    DIRT_CLOUD_ASSET_RETENTION_DAYS \
    DIRT_CLOUD_ASSET_PUBLIC_BASE_URL \
    DIRT_CLOUD_BUCKET_NAME \
    DIRT_CLOUD_COMMAND_CREATION_ENABLED \
    DIRT_CLOUD_GATEWAY_COMMAND_CLAIM_ENABLED \
    DIRT_CLOUD_S3_ACCESS_KEY_ID \
    DIRT_CLOUD_S3_ENDPOINT \
    DIRT_CLOUD_S3_REGION \
    DIRT_CLOUD_S3_SECRET_ACCESS_KEY \
    DIRT_CLOUD_SITE_ID
do
    sync_railway_variable_from_env "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID" "$name"
done
sync_required_railway_variable_from_env \
    "$RAILWAY_WEB_UI_SERVICE_ID" VITE_DIRT_API_BASE_URL

echo "Applying cloud Atlas migrations..."
atlas migrate apply --env cloud

echo "Deploying control-plane API to Railway service control-plane-api..."
railway up "$ROOT_DIR/apps/control-plane" \
    --path-as-root \
    --project "$RAILWAY_PROJECT_ID" \
    --environment "$RAILWAY_ENVIRONMENT" \
    --service "$RAILWAY_CONTROL_PLANE_API_SERVICE_ID"

if [ "$SKIP_SMOKE" -eq 0 ]; then
    wait_for_http "cloud API health" "$DIRT_CLOUD_API_BASE_URL/api/health"
fi

echo "Deploying web UI to Railway service web-ui..."
railway up "$ROOT_DIR/web-ui" \
    --path-as-root \
    --project "$RAILWAY_PROJECT_ID" \
    --environment "$RAILWAY_ENVIRONMENT" \
    --service "$RAILWAY_WEB_UI_SERVICE_ID"

if [ "$SKIP_SMOKE" -eq 0 ]; then
    wait_for_http "hosted UI" "$DIRT_CLOUD_UI_BASE_URL/"
fi

echo "Control-plane deploy finished."
