#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Agent-side W&B reader. JSON output for pipe-into-jq.

  show RUN          — full dump (config, summary, tags, system); downloads
                      output.log + metadata files to var/wake-word/wandb-pulls/<id>/
  group GROUP       — every run in a WANDB_RUN_GROUP (id/state/name/runtime only)
  latest [--n N]    — N most recent runs (default 5; same row shape as group)

RUN may be `run_id` or `entity/project/run_id`.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import warnings
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

warnings.filterwarnings("ignore", category=UserWarning, module="pydantic")

DEFAULT_PROJECT = "dirt-wake-word"
PULLS_ROOT = rp.repo_root() / "var" / "wake-word" / "wandb-pulls"
SAVED_FILES = (
    "output.log", "config.yaml", "requirements.txt",
    "wandb-metadata.json", "wandb-summary.json",
)


def _api():
    os.environ.setdefault("WANDB_SILENT", "true")
    import wandb

    rp.load_env()
    if not os.environ.get("WANDB_API_KEY"):
        sys.exit("error: WANDB_API_KEY not set in environment (.env)")
    return wandb.Api()


def _run_row(run) -> dict:
    return {
        "id": run.id,
        "name": run.name,
        "url": run.url,
        "state": run.state,
        "group": run.group,
        "tags": list(run.tags),
        "created_at": str(run.created_at),
        "runtime_s": run.summary.get("_runtime"),
    }


def _run_full(run, *, dest: Path) -> dict:
    d = _run_row(run)
    d["job_type"] = run.job_type
    d["config"] = dict(run.config)
    d["summary"] = {k: v for k, v in run.summary.items() if not k.startswith("_")}

    dest.mkdir(parents=True, exist_ok=True)
    saved: list[str] = []
    for name in SAVED_FILES:
        try:
            run.file(name).download(root=str(dest), replace=True, exist_ok=True)
            saved.append(str(dest / name))
        except Exception:  # noqa: BLE001 — file may not exist yet for in-flight runs
            pass
    d["local_files"] = saved

    md = dest / "wandb-metadata.json"
    if md.exists():
        try:
            meta = json.loads(md.read_text())
            d["system"] = {
                "host": meta.get("host"),
                "python": meta.get("python"),
                "os": meta.get("os"),
                "gpu": meta.get("gpu"),
                "cpu_count": meta.get("cpu_count"),
                "git_commit": (meta.get("git") or {}).get("commit"),
            }
        except (OSError, json.JSONDecodeError) as exc:
            d["system"] = {"_error": repr(exc)}
    return d


def main() -> int:
    p = argparse.ArgumentParser()
    p.add_argument("--entity")
    p.add_argument("--project", default=DEFAULT_PROJECT)
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("show").add_argument("run")
    sub.add_parser("group").add_argument("group")
    sub.add_parser("latest").add_argument("--n", type=int, default=5)
    args = p.parse_args()

    api = _api()
    entity = args.entity or api.default_entity

    if args.cmd == "show":
        parts = args.run.split("/")
        if len(parts) == 1:
            path = f"{entity}/{args.project}/{parts[0]}"
        elif len(parts) == 3:
            path = args.run
        else:
            sys.exit(f"error: {args.run!r} — expected run_id or entity/project/run_id")
        run = api.run(path)
        d = _run_full(run, dest=PULLS_ROOT / run.id)

    elif args.cmd == "group":
        runs = sorted(
            api.runs(f"{entity}/{args.project}", filters={"group": args.group}),
            key=lambda r: r.created_at,
        )
        if not runs:
            sys.exit(f"no runs in group {args.group!r} under {entity}/{args.project}")
        d = [_run_row(r) for r in runs]

    else:  # latest
        runs = list(
            api.runs(
                f"{entity}/{args.project}",
                order="-created_at",
                per_page=args.n,
            )
        )[: args.n]
        d = [_run_row(r) for r in runs]

    json.dump(d, sys.stdout, indent=2, default=str)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
