#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Submit one wake-word training job to RunPod, S3-poll for the volume
sentinel, pull artifacts via the S3 API, DELETE.

The entrypoint writes /workspace/out/<RUNPOD_POD_ID>/{SUCCESS,FAILURE}
on the volume. The orchestrator polls s3://<volume>/out/<pod_id>/ for
that sentinel via S3 head, then downloads each known artifact filename
directly (RunPod's list_objects_v2 leaks tokens across prefixes, so
anything that lists — including `aws s3 sync` — eventually loops) and
DELETEs the pod. desiredStatus is user-intent (not container state) so
RunPod will auto-restart the container on exit until we DELETE; the
poll-interval-sized race is bounded waste.
"""

from __future__ import annotations

import argparse
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

DEFAULT_IMAGE = "ghcr.io/akravetz/dirt-wake-word-trainer:latest"
DEFAULT_GPU_PRIORITY = [
    "NVIDIA GeForce RTX 4090",
    "NVIDIA L4",
    "NVIDIA RTX A4000",
]
MAX_WALL_S = 4 * 60 * 60


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--image", default=DEFAULT_IMAGE)
    parser.add_argument("--gpu", action="append", default=None)
    parser.add_argument("--keep", action="store_true")
    parser.add_argument("--run-group", default=None)
    parser.add_argument(
        "--env",
        action="append",
        default=[],
        metavar="KEY=VALUE",
        help="Extra environment variable to inject into the trainer container.",
    )
    args = parser.parse_args()

    rp.load_env()
    api_key = rp.env("RUNPOD_API_KEY")
    network_volume_id = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    registry_auth_id = rp.env("RUNPOD_GHCR_AUTH_ID", required=False) or None
    wandb_api_key = rp.env("WANDB_API_KEY", required=False) or ""

    name = f"wakeword-train-{time.strftime('%Y%m%d-%H%M%S')}"
    run_group = args.run_group or f"solo-{time.strftime('%Y%m%d')}"

    body = {
        "name": name,
        "networkVolumeId": network_volume_id,
        "volumeMountPath": "/workspace",
        "cloudType": "SECURE",
        "interruptible": False,
        "imageName": args.image,
        "computeType": "GPU",
        "gpuTypeIds": args.gpu or DEFAULT_GPU_PRIORITY,
        "gpuTypePriority": "availability",
        "gpuCount": 1,
        "containerDiskInGb": 50,
        "env": {
            "WANDB_RUN_GROUP": run_group,
            "WANDB_NAME": name,
            "DIRT_IMAGE_REF": args.image,
            # Pass our RunPod API key into the container so the entrypoint
            # can self-DELETE after writing the sentinel. Belt-and-suspenders
            # with the orchestrator's `finally:` DELETE — if the orchestrator
            # dies mid-run, the entrypoint stops the pod itself.
            "RUNPOD_API_KEY": api_key,
        },
    }
    if registry_auth_id:
        body["containerRegistryAuthId"] = registry_auth_id
    if wandb_api_key:
        body["env"]["WANDB_API_KEY"] = wandb_api_key
    for item in args.env:
        if "=" not in item:
            parser.error(f"--env must be KEY=VALUE, got {item!r}")
        key, value = item.split("=", 1)
        key = key.strip()
        if not key:
            parser.error(f"--env must have a non-empty key, got {item!r}")
        body["env"][key] = value

    http = rp.client(api_key)
    train_pod_id = rp.create_pod(http, body)
    print(f"==> created training pod {train_pod_id} (image={args.image})")

    local_dest = (
        rp.repo_root() / "var" / "wake-word" / "models"
        / f"{time.strftime('%Y-%m-%d-%H%M%S')}-{train_pod_id}"
    )
    deadline = time.monotonic() + MAX_WALL_S
    s3 = rp.s3_client()

    prefix = f"out/{train_pod_id}/"
    with rp.leased_pod(http, train_pod_id, keep_on_success=args.keep):
        sentinel = rp.wait_for_s3_sentinel(
            s3, bucket=network_volume_id, prefix=prefix, deadline=deadline,
        )
        print(f"==> sentinel={sentinel} at s3://{network_volume_id}/{prefix}")
        print(f"==> pulling artifacts → {local_dest}")
        rp.pull_artifacts(
            s3,
            bucket=network_volume_id,
            prefix=prefix,
            dest=local_dest,
            filenames=rp.TRAINER_ARTIFACTS,
        )

    if (local_dest / "SUCCESS").exists():
        print(f"=== training succeeded; artifacts at {local_dest} ===")
        return 0
    if (local_dest / "FAILURE").exists():
        print(
            f"=== training failed; see {local_dest / 'FAILURE'} for traceback ===",
            file=sys.stderr,
        )
        return 1
    print(
        f"=== no SUCCESS or FAILURE in {local_dest} — entrypoint never wrote one ===",
        file=sys.stderr,
    )
    return 2


if __name__ == "__main__":
    sys.exit(main())
