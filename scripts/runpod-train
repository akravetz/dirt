#!/usr/bin/env -S uv run --project /home/akcom/code/dirt python -u
"""Submit one wake-word training job to RunPod, poll, pull artifacts back.

POST a pod via the
RunPod Pods via the REST v1 API. See docs/references/runpod/INDEX.md for
the rationale behind every field choice; shared lifecycle primitives live
in scripts/_runpod_lib.py.

Required env (.env):
  RUNPOD_API_KEY              — bearer token (console.runpod.io/user/settings)
  RUNPOD_NETWORK_VOLUME_ID    — volume holding the seeded datasets
  RUNPOD_GHCR_AUTH_ID         — (optional) for private GHCR images

SSH key: ~/.ssh/runpod_ed25519[.pub]. Public key gets injected into the
container via PUBLIC_KEY env (the runpod/pytorch base wires it into
authorized_keys); private key drives the post-EXIT SCP pull.

Usage:
  scripts/runpod-train                      # default image, 4090 first
  scripts/runpod-train --image <ref>
  scripts/runpod-train --gpu "NVIDIA L4"    # override; repeat for fallback
  scripts/runpod-train --keep               # debug only — leave pod alive on success
"""

from __future__ import annotations

import argparse
import subprocess
import sys
import time
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _runpod_lib as rp  # noqa: E402

DEFAULT_IMAGE = "ghcr.io/akravetz/dirt-wake-word-trainer:latest"
DEFAULT_GPU_PRIORITY = [
    "NVIDIA GeForce RTX 4090",
    "NVIDIA L4",
    "NVIDIA RTX A4000",
]
# 4 h hard cap on a 30–90 min expected run — enough headroom for image pull
# stalls without paying for a stuck container all night.
MAX_WALL_S = 4 * 60 * 60


def _classify_outcome(local_dest: Path) -> tuple[int, str]:
    """Read sentinels from the SCP'd /workspace/out/ — single-source result."""
    if (local_dest / "SUCCESS").exists():
        return 0, f"=== training succeeded; artifacts at {local_dest} ==="
    if (local_dest / "FAILURE").exists():
        return 1, (
            f"=== training failed; see {local_dest / 'FAILURE'} for traceback ==="
        )
    return 2, (
        f"=== no SUCCESS or FAILURE sentinel in {local_dest} — "
        "container exited before the entrypoint could write one ==="
    )


def _wait_for_sentinel(ip: str, port: int, *, deadline: float) -> str:
    """SSH-poll for /workspace/out/SUCCESS or /workspace/out/FAILURE."""
    cmd = (
        "if [ -f /workspace/out/SUCCESS ]; then echo SUCCESS; "
        "elif [ -f /workspace/out/FAILURE ]; then echo FAILURE; fi"
    )
    while time.monotonic() < deadline:
        try:
            r = subprocess.run(
                [
                    "ssh",
                    "-i", str(rp.SSH_KEY_PATH),
                    "-o", "StrictHostKeyChecking=accept-new",
                    "-o", "UserKnownHostsFile=/dev/null",
                    "-o", "ConnectTimeout=10",
                    "-p", str(port),
                    f"root@{ip}",
                    cmd,
                ],
                capture_output=True, text=True, timeout=20,
            )
            out = r.stdout.strip()
            if out in ("SUCCESS", "FAILURE"):
                return out
        except subprocess.SubprocessError:
            pass  # sshd not yet up, or transient — retry
        print(f"  {time.strftime('%H:%M:%S')} (waiting for sentinel)")
        time.sleep(30)
    raise TimeoutError("trainer did not write a sentinel within deadline")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--image", default=DEFAULT_IMAGE)
    parser.add_argument(
        "--gpu",
        action="append",
        default=None,
        help="GPU priority list (repeat for multiple). Default: 4090, L4, A4000.",
    )
    parser.add_argument(
        "--keep",
        action="store_true",
        help="Skip DELETE on success — for inspecting a finished pod.",
    )
    args = parser.parse_args()

    rp.load_env()
    api_key = rp.env("RUNPOD_API_KEY")
    network_volume_id = rp.env("RUNPOD_NETWORK_VOLUME_ID")
    registry_auth_id = rp.env("RUNPOD_GHCR_AUTH_ID", required=False) or None
    pub_key = rp.public_key(required=True)

    name = f"wakeword-train-{time.strftime('%Y%m%d-%H%M%S')}"
    local_dest = (
        rp.repo_root() / "var" / "wake-word" / "models"
        / time.strftime("%Y-%m-%d-%H%M%S-runpod")
    )
    deadline = time.monotonic() + MAX_WALL_S

    body = rp.common_pod_body(
        name=name, network_volume_id=network_volume_id, public_key=pub_key
    ) | {
        "imageName": args.image,
        "computeType": "GPU",
        "gpuTypeIds": args.gpu or DEFAULT_GPU_PRIORITY,
        "gpuTypePriority": "availability",
        "gpuCount": 1,
        # Image is ~12 GB; 50 GB ephemeral leaves comfortable headroom for
        # the container's /tmp + intermediate scratch outside the volume.
        "containerDiskInGb": 50,
    }
    if registry_auth_id:
        body["containerRegistryAuthId"] = registry_auth_id

    http = rp.client(api_key)
    pod_id = rp.create_pod(http, body)
    print(f"created pod {pod_id} (image={args.image})")

    with rp.leased_pod(http, pod_id, keep_on_success=args.keep):
        ip, port = rp.wait_for_endpoint(http, pod_id, deadline=deadline)
        print(f"pod {pod_id} reachable at {ip}:{port}")

        # Container always exits 0; on completion it writes SUCCESS or
        # FAILURE under /workspace/out and `_hold()`s so sshd stays up.
        # SSH-poll the sentinel; once seen, SCP /workspace/out off.
        sentinel = _wait_for_sentinel(ip, port, deadline=deadline)
        print(f"==> sentinel={sentinel}; pulling /workspace/out -> {local_dest}")
        rp.scp_pull(ip=ip, port=port, remote_dir="/workspace/out", local_dest=local_dest)

    rc, msg = _classify_outcome(local_dest)
    print(msg, file=sys.stderr if rc else sys.stdout)
    return rc


if __name__ == "__main__":
    sys.exit(main())
