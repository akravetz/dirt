// Template for fan_controller secrets.h.
//
// Copy this file to `include/secrets.h` (gitignored) and fill in values.
// WiFi + ingest credentials are shared across the whole ESP32 fleet
// (plant_node, tent_node, fan_controller) — pull them from the repo-root
// .env (DIRT_SENSOR_INGEST_TOKEN) and match whatever the plant_node
// secrets.h files have for WIFI_*, SERVER_URL, OTA_PASSWORD.

#pragma once

#define WIFI_SSID            "YOUR_SSID"
#define WIFI_PASSWORD        "YOUR_PASSWORD"

#define SERVER_URL           "http://homebox.local:8000/api/ingest/sensors"
#define SENSOR_INGEST_TOKEN  "YOUR_TOKEN"

#define OTA_PASSWORD         "YOUR_OTA_PASSWORD"
